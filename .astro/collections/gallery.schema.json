{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "category": {
      "type": "string"
    },
    "bgColor": {
      "type": "string"
    },
    "textColor": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "thumbnail": {
      "type": "object",
      "properties": {
        "url": {
          "anyOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "string"
            }
          ]
        },
        "alt": {
          "type": "string"
        }
      },
      "required": [
        "url",
        "alt"
      ]
    },
    "thumbnailClass": {
      "type": "string"
    },
    "imageGrid": {
      "type": "string"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "anyOf": [
              {
                "type": "string",
                "format": "uri"
              },
              {
                "type": "string"
              }
            ]
          },
          "alt": {
            "type": "string"
          },
          "class": {
            "type": "string"
          }
        },
        "required": [
          "url",
          "alt"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "category",
    "title",
    "description",
    "thumbnail"
  ]
}