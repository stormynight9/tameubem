---
import { AstroSeo } from "@lexingtonthemes/seo";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const SITE_NAME = "Ta Meu Bem";
const DEFAULT_DESCRIPTION =
  "Handmade beadwork, jewelry, and photography by Ta Meu Bem.";

const {
  title,
  description = DEFAULT_DESCRIPTION,
  canonical = Astro.site
    ? new URL(Astro.url.pathname, Astro.site).href
    : Astro.url.href,
} = Astro.props;

const seoTitle = title ? `${title} | ${SITE_NAME}` : SITE_NAME;
---

<AstroSeo
  title={seoTitle}
  description={description}
  canonical={canonical}
  openGraph={{
    url: canonical,
    title: seoTitle,
    description,
    site_name: SITE_NAME,
    type: "website",
    locale: "en_US",
  }}
  twitter={{
    cardType: "summary_large_image",
  }}
/>
